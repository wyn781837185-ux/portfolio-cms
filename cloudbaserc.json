{
  "envId": "your-cloudbase-env-id",
  "framework": {
    "name": "portfolio-cms",
    "plugins": {
      "node": {
        "use": "@cloudbase/framework-plugin-node",
        "inputs": {
          "entry": "server.js",
          "path": "/",
          "name": "portfolio-cms",
          "platform": "function",
          "functionOptions": {
            "timeout": 10,
            "envVariables": {
              "ADMIN_TOKEN": "change-this-admin-token"
            }
          }
        }
      }
    }
  }
}
